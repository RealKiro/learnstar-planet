dist/
build/
frontend-vue/dist/

# ========== Docker ==========
docker/data/
docker/volumes/
*.tar.gz

# ========== Test & Coverage ==========
coverage/
backend/coverage.xml
backend/coverage-html/

# ========== Environment ==========
.env
.env.*
!.env.example
*.log

