# Ignore files for Docker build (reduces build context & image size)
# Build context = backend/ directory

# Git
.git
.gitignore
.gitattributes

# CI/CD
.github/
.gitee/
.travis.yml
.codecov.yml

# IDE and editor
.idea/
.vscode/
*.swp
*.swo
*.bak
*~
.DS_Store
Thumbs.db

# PHP dev tools & configs (not needed in production image)
/vendor/
.php-cs-fixer.php
.php-cs-fixer-cache
phpstan.neon
phpunit.xml
phpunit.xml.dist
coverage.xml
coverage-html/
infection.json
infection.json.dist

# Laravel runtime (created by entrypoint)
/storage/
/bootstrap/cache/

# Environment files
.env
.env.local
.env.production
.env.staging
.env.testing
*.log

# Node.js
/node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# Testing
/tests/
/coverage/

# Documentation
/*.md
/docs/

# Archives
*.tar
*.gz
*.zip
*.rar

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker files themselves (not needed inside image)
Dockerfile
Dockerfile.dev
.dockerignore

# Makefile (dev convenience only)
Makefile
