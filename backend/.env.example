# ===== 学趣星球 - 环境配置 =====
# 所有功能全免费，无VIP概念

APP_NAME="学趣星球"
APP_ENV=production
APP_KEY=base64:GenerateWithArtisanKeyGenerate
APP_DEBUG=false
APP_URL=https://your-domain.com

# ===== 数据库（支持 MySQL/MariaDB/PostgreSQL/SQLite） =====
# 切换数据库只需修改 DB_CONNECTION
# mysql → MySQL/MariaDB（推荐生产环境）
# pgsql → PostgreSQL（推荐大规模部署）
# sqlite → SQLite（推荐开发/小规模）

DB_CONNECTION=mysql
DB_HOST=mysql          # Docker环境用容器名，独立部署填实际IP
DB_PORT=3306
DB_DATABASE=learnstar
DB_USERNAME=learnstar
DB_PASSWORD=ChangeThisToStrongPassword

# PostgreSQL 配置（当 DB_CONNECTION=pgsql 时使用）
# DB_HOST=pgsql
# DB_PORT=5432

# ===== Redis（必须独立部署，不内置） =====
REDIS_HOST=redis       # Docker环境用容器名
REDIS_PASSWORD=null
REDIS_PORT=6379

# Redis DB分区
# DB 0: 默认缓存
# DB 1: 排行榜（ZSET）
# DB 2: 会话
# DB 3: 广播队列

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ===== 第三方登录配置 =====
# 微信开放平台（扫码登录Web端）
WECHAT_OPEN_APPID=your_wechat_open_appid
WECHAT_OPEN_SECRET=your_wechat_open_secret

# 微信小程序
WECHAT_MINI_APPID=your_mini_program_appid
WECHAT_MINI_SECRET=your_mini_program_secret

# 企业微信
WECHAT_WORK_CORPID=your_corp_id
WECHAT_WORK_SECRET=your_corp_secret
WECHAT_WORK_AGENTID=your_agent_id

# QQ互联
QQ_APPID=your_qq_appid
QQ_APPKEY=your_qq_appkey

# 人人通空间
RENREN_APPID=your_renren_appid
RENREN_SECRET=your_renren_secret

# ===== 广播（实时推送积分变化到家长端） =====
BROADCAST_DRIVER=redis

# ===== 文件存储 =====
FILESYSTEM_DRIVER=local
# 生产环境推荐 OSS/S3
# FILESYSTEM_DRIVER=s3

# ===== Sanctum API认证 =====
SANCTUM_STATEFUL_DOMAINS=your-domain.com

# ===== 学校管理员初始账号 =====
# 部署后第一个管理员账号（运行 php artisan db:seed 自动创建）
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeThisImmediately

# ===== 日志 =====
LOG_CHANNEL=daily
LOG_LEVEL=info
