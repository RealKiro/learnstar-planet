# PHPStan configuration with Larastan for Laravel support

includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5

    paths:
        - app
        - routes

    # PHPStan stub files (for helper functions not detected automatically)
    stubFiles:
        - tests/phpstan-stubs/flux.php
        - tests/phpstan-stubs/global-helpers.php

    # Scanned files for class discovery
    scanFiles:
        - tests/phpstan-stubs/overtrue-pinyin.php

    # Treat PHPDoc types as not always certain (avoids false "always true" warnings)
    treatPhpDocTypesAsCertain: false

    excludePaths:
        analyseAndScan:
            - app/Support/helpers.php (?)
            - app/Providers/BroadcastServiceProvider.php (?)
            - vendor
            - storage (?)
            - bootstrap/cache

    # 忽略某些错误（仅保留实际匹配的错误）
    ignoreErrors:
        - '#Call to an undefined method .*#'
        - '#Access to an undefined property .*#'
        - message: '#Call to static method permalink\(\) on an unknown class Overtrue\\Pinyin\\Pinyin\.#'
          reportUnmatched: false
        - message: '#Function flux not found\.#'
          reportUnmatched: false
        - message: '#Parameter \#1 \$callback of method Illuminate\\Database\\Eloquent\\Collection<.*>::map\(\) contains unresolvable type\.#'
          reportUnmatched: false
        - message: '#Method App\\Models\\WechatWorkLeaveRecord::getUnsyncedForDate\(\) should return Illuminate\\Database\\Eloquent\\Collection<int, static\(App\\Models\\WechatWorkLeaveRecord\)> but returns Illuminate\\Database\\Eloquent\\Collection<int, App\\Models\\WechatWorkLeaveRecord>\.#'
          reportUnmatched: false
        - message: '#expects callable.*Closure\(App\\Models\\Student\)#'
          reportUnmatched: false
