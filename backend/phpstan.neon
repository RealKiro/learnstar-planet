# PHPStan configuration with Larastan for Laravel support

includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5

    paths:
        - app
        - routes

    excludePaths:
        analyseAndScan:
            - app/Support/helpers.php (?)
            - app/Providers/BroadcastServiceProvider.php (?)
            - vendor
            - storage (?)
            - bootstrap/cache

    # 忽略某些错误
    ignoreErrors:
        - '#Call to an undefined method .*#'
        - '#Access to an undefined property .*#'
        - '#Cannot call method .*#'
        - '#Method .* has no return typehint#'
        - '#Method .* constructor has a unused parameter#'

    # 类型检查
    checkMissingIterableValueType: false
    checkGenericClassInNonGenericObjectType: false

    # 内存限制
    memoryLimit: 512M
