# PHPStan configuration with Larastan for Laravel support

includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5

    paths:
        - app
        - routes

    # PHPStan stub files (for helper functions not detected automatically)
    stubFiles:
        - tests/phpstan-stubs/flux.php
        - tests/phpstan-stubs/global-helpers.php
        - tests/phpstan-stubs/overtrue-pinyin.php

    # Treat PHPDoc types as not always certain (avoids false "always true" warnings)
    treatPhpDocTypesAsCertain: false

    excludePaths:
        analyseAndScan:
            - app/Support/helpers.php (?)
            - app/Providers/BroadcastServiceProvider.php (?)
            - vendor
            - storage (?)
            - bootstrap/cache

    # 忽略某些错误（仅保留实际匹配的错误）
    ignoreErrors:
        - '#Call to an undefined method .*#'
        - '#Access to an undefined property .*#'
        - message: '#Function flux not found\.#'
          reportUnmatched: false
