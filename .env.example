# ============================================================
# 学趣星球 环境变量配置
# 复制此文件为 .env 并根据你的数据库类型修改配置
# ============================================================

# ===== 基础配置 =====
APP_NAME=学趣星球
APP_ENV=production
APP_DEBUG=false

# ============================================================
# 应用访问地址
# ============================================================
#
# APP_URL：协议 + IP/域名，不需要带端口
# APP_PORT：端口号，改端口只改这里
#
# 容器启动时自动拼接，例如：
#   APP_URL=http://192.168.1.100  +  APP_PORT=8080  → http://192.168.1.100:8080
#   APP_URL=http://192.168.1.100  +  APP_PORT=7900  → http://192.168.1.100:7900
#   APP_URL=http://192.168.1.100  +  APP_PORT=80    → http://192.168.1.100（80不拼接）
#
#   本机测试：  APP_URL=http://localhost
#   局域网访问：APP_URL=http://192.168.1.100

APP_URL=http://localhost
APP_PORT=8080

# GitHub 用户名（用于拉取 GHCR 镜像，源作者已预置）
# ⚠️ GHCR 镜像路径要求全小写，所以 RealKiro → realkiro
# 如果你 Fork 了仓库自行构建，改为你的 GitHub 用户名（小写）
GITHUB_USERNAME=realkiro


# ============================================================
# ===== 数据库配置 =====
# ============================================================
#
# 三种数据库类型，选择其一（默认 MySQL 内置容器）：
#
#   类型           DB_CONNECTION   内置/外置                     启动命令
#   ──────────────────────────────────────────────────────────────────────
#   MySQL/MariaDB  mysql           DB_HOST=mysql → 内置容器      docker-compose up -d
#                                  DB_HOST=IP    → 外置数据库    docker-compose up -d app --no-deps
#   SQLite         sqlite          无内置/外置（文件数据库）       docker-compose up -d app --no-deps
#   PostgreSQL     pgsql           仅外置（无内置 PG 容器）       docker-compose up -d app --no-deps
#
# ⚠️ MYSQL_ROOT_PASSWORD / MYSQL_PORT 仅内置 MySQL 容器使用，其他类型忽略


# ──────────────────────────────────────────────────────────
# 一、MySQL / MariaDB（默认 · 推荐）
# ──────────────────────────────────────────────────────────

# ▸ 内置容器（默认）—— DB_HOST=mysql 表示使用 docker-compose 内置的 mysql:8.0
#   首次启动自动创建数据库和业务账号，开箱即用
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=learnstar
DB_USERNAME=learnstar
DB_PASSWORD=learnstar_password
# 内置 MySQL 容器专用：root 超管密码 + 宿主机暴露端口
# ⚠️ Laravel 不读取 MYSQL_ROOT_PASSWORD，它仅用于 MySQL 镜像初始化
MYSQL_ROOT_PASSWORD=root_strong_password
MYSQL_PORT=3306

# ▸ 外置 MySQL / MariaDB —— 取消注释，注释掉上方内置配置
#   DB_HOST 填外部数据库地址，需提前手动创建 learnstar 库
#
# DB_CONNECTION=mysql
# DB_HOST=192.168.1.50           # ← 外部数据库 IP 或域名
# DB_PORT=3306
# DB_DATABASE=learnstar
# DB_USERNAME=root               # ← 外部数据库用户名
# DB_PASSWORD=your_password      # ← 外部数据库密码
# 启动：docker-compose up -d app --no-deps


# ──────────────────────────────────────────────────────────
# 二、SQLite（最简单 · 无需数据库服务）
# ──────────────────────────────────────────────────────────
# 文件数据库，不需要 DB_HOST/DB_PORT，数据库文件自动创建于 storage/database.sqlite
# 适合小型部署（< 500 学生）
# ⚠️ 无 Redis 时需同步修改下方缓存配置为 file/database
#
# DB_CONNECTION=sqlite
# DB_HOST=
# DB_PORT=
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=
# CACHE_DRIVER=file
# SESSION_DRIVER=file
# QUEUE_CONNECTION=database
# 启动：docker-compose up -d app --no-deps


# ──────────────────────────────────────────────────────────
# 三、PostgreSQL（仅外置）
# ──────────────────────────────────────────────────────────
# docker-compose 无内置 PG 容器，需连接外部 PostgreSQL
# 需在 PG 中手动创建数据库和用户
#
# DB_CONNECTION=pgsql
# DB_HOST=192.168.1.50           # ← PostgreSQL 地址
# DB_PORT=5432
# DB_DATABASE=learnstar
# DB_USERNAME=learnstar_user
# DB_PASSWORD=your_pg_password
# 启动：docker-compose up -d app --no-deps


# ===== 超级管理员配置（首次部署时自动创建）=====
# 启动时会自动创建一个默认学校和一个 school_admin 账号
# 如果该用户名已存在，则不会重复创建，也不会修改密码
# ⚠️ 生产环境请务必修改默认密码！
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_NAME=系统管理员
ADMIN_SCHOOL_NAME=学趣星球默认学校
ADMIN_SCHOOL_CODE=learnstar-default


# ===== Redis 配置 =====
# 内置 Redis 容器：保持默认（REDIS_HOST=redis 是 Docker 内部网络名）
# 外部 Redis：改为外部地址
# ⚠️ 使用 SQLite 且无 Redis 时，需同步修改下方缓存配置（改为 file/database）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== 缓存配置 =====
# 使用内置/外部 Redis 时保持默认
# ⚠️ 使用 SQLite 且无 Redis 时，改为：
#   CACHE_DRIVER=file
#   SESSION_DRIVER=file
#   QUEUE_CONNECTION=database
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis


# ===== AI 功能配置（可选）=====
# 支持：qwen / openai / deepseek / moonshot
# 没有 API Key？没关系！所有核心功能都可正常使用，AI 在配置后自动启用
AI_PROVIDER=
AI_API_KEY=
AI_API_BASE=
AI_MODEL=qwen-turbo
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7


# ===== 第三方登录配置（可选）=====
# 微信公众号
WECHAT_OFFICIAL_APPID=
WECHAT_OFFICIAL_SECRET=

# 企业微信
WECHAT_WORK_CORPID=
WECHAT_WORK_AGENTID=
WECHAT_WORK_SECRET=

# QQ 登录
QQ_APPID=
QQ_APPSECRET=

# 人人通空间
RENREN_CLIENT_ID=
RENREN_CLIENT_SECRET=


# ===== 文件上传配置 =====
FILESYSTEM_DISK=local
UPLOAD_MAX_SIZE=10


# ===== 邮件配置（可选）=====
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=学趣星球
