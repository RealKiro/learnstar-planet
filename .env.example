# 学趣星球环境变量配置
# 复制此文件为 .env 并修改对应配置

# ===== 基础配置 =====
APP_NAME=学趣星球
APP_ENV=production
APP_DEBUG=false
# 应用访问 IP 或域名（只改这里，不要改下面的 APP_URL）
# 示例：
#   公网服务器：your-server-ip
#   局域网 NAS（群晖/飞牛）：192.168.1.100
#   本机测试：localhost
#   有域名/反代：learnstar.yourdomain.com
# ⚠️ 不要用 Docker 容器内部 IP（如 172.17.0.x），其他设备访问不到
APP_HOST=localhost

# 应用端口（宿主机/外网访问端口，容器内部固定为 8080 不可改）
# 映射关系：http://你的IP:<APP_PORT>  →  容器内部 8080（Nginx 监听端口）
# 如果 8080 被其他应用占用，可改为任意未被占用的端口，例如 8081、8090、9000
# 改为 80 可直接用 http://ip 访问（可能需要 root 权限，NAS 上不建议）
APP_PORT=8080

# APP_URL 由上面的 APP_HOST 和 APP_PORT 自动拼接，一般无需手动修改
# 如果你使用 https 或自定义路径，可以手动覆盖
APP_URL=http://${APP_HOST}:${APP_PORT}

# GitHub用户名（用于拉取GHCR镜像，源作者已预置，无需修改）
GITHUB_USERNAME=realkiro

# ===== 数据库配置 =====
# 选项：mysql / pgsql / sqlite
DB_CONNECTION=mysql

# 如果使用内置MySQL容器，保持默认
# 如果使用外部数据库，修改为外部地址
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=learnstar
DB_USERNAME=learnstar
DB_PASSWORD=learnstar_password
MYSQL_ROOT_PASSWORD=root_strong_password
MYSQL_PORT=3306

# ===== Redis 配置 =====
# 如果使用内置Redis容器，保持默认
# 如果使用外部Redis，修改为外部地址
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== 缓存配置 =====
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ===== AI 功能配置（可选）=====
# 支持：qwen / openai / deepseek / moonshot
AI_PROVIDER=
AI_API_KEY=
AI_API_BASE=
AI_MODEL=qwen-turbo
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# ===== 第三方登录配置（可选）=====
# 微信公众号
WECHAT_OFFICIAL_APPID=
WECHAT_OFFICIAL_SECRET=

# 企业微信
WECHAT_WORK_CORPID=
WECHAT_WORK_AGENTID=
WECHAT_WORK_SECRET=

# QQ登录
QQ_APPID=
QQ_APPSECRET=

# 人人通空间
RENREN_CLIENT_ID=
RENREN_CLIENT_SECRET=

# ===== 文件上传配置 =====
FILESYSTEM_DISK=local
UPLOAD_MAX_SIZE=10

# ===== 邮件配置（可选）=====
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=学趣星球
