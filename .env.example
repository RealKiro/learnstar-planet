# 学趣星球环境变量配置
# 复制此文件为 .env 并修改对应配置

# ===== 基础配置 =====
APP_NAME=学趣星球
APP_ENV=production
APP_DEBUG=false
APP_URL=http://your-server-ip

# GitHub用户名（用于拉取GHCR镜像）
GITHUB_USERNAME=yourusername

# 应用端口
APP_PORT=80

# ===== 数据库配置 =====
# 选项：mysql / pgsql / sqlite
DB_CONNECTION=mysql

# 如果使用内置MySQL容器，保持默认
# 如果使用外部数据库，修改为外部地址
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=learnstar
DB_USERNAME=learnstar
DB_PASSWORD=learnstar_password
MYSQL_ROOT_PASSWORD=root_strong_password
MYSQL_PORT=3306

# ===== Redis 配置 =====
# 如果使用内置Redis容器，保持默认
# 如果使用外部Redis，修改为外部地址
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== 缓存配置 =====
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ===== AI 功能配置（可选）=====
# 支持：qwen / openai / deepseek / moonshot
AI_PROVIDER=
AI_API_KEY=
AI_API_BASE=
AI_MODEL=qwen-turbo
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# ===== 第三方登录配置（可选）=====
# 微信公众号
WECHAT_OFFICIAL_APPID=
WECHAT_OFFICIAL_SECRET=

# 企业微信
WECHAT_WORK_CORPID=
WECHAT_WORK_AGENTID=
WECHAT_WORK_SECRET=

# QQ登录
QQ_APPID=
QQ_APPSECRET=

# 人人通空间
RENREN_CLIENT_ID=
RENREN_CLIENT_SECRET=

# ===== 文件上传配置 =====
FILESYSTEM_DISK=local
UPLOAD_MAX_SIZE=10

# ===== 邮件配置（可选）=====
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=学趣星球
