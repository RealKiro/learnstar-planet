# ============================================================
# 学趣星球 环境变量配置
# 复制此文件为 .env 并根据你的部署场景修改配置
# ============================================================
#
# 部署场景速查（无需 --profile 参数）：
#   场景一：内置 MySQL 容器（默认）  → 保持默认值，docker-compose up -d
#   场景二：外部 MySQL/MariaDB      → 改 DB_HOST/DB_USERNAME/DB_PASSWORD，docker-compose up -d app --no-deps
#   场景三：SQLite                  → 改 DB_CONNECTION=sqlite + 缓存改 file，docker-compose up -d app --no-deps
#   场景四：PostgreSQL              → 参考下方注释块，docker-compose up -d app --no-deps
#

# ===== 基础配置 =====
APP_NAME=学趣星球
APP_ENV=production
APP_DEBUG=false

# 应用访问 IP 或域名（只改这里，不要改下面的 APP_URL）
# 示例：
#   公网服务器：your-server-ip
#   局域网 NAS（群晖/飞牛）：192.168.1.100
#   本机测试：localhost
#   有域名/反代：learnstar.yourdomain.com
# ⚠️ 不要用 Docker 容器内部 IP（如 172.17.0.x），其他设备访问不到
APP_HOST=localhost

# 宿主机访问端口（容器内部固定为 8080，不要改 docker-compose 里的 8080）
# 如果 8080 被占用，改成 8081/8090/9000 等未被占用的端口
# 改为 80 可直接用 http://ip 访问（可能需要 root 权限，NAS 上不建议）
APP_PORT=8080

# APP_URL 由 APP_HOST 和 APP_PORT 自动拼接，一般无需手动修改
# 如果你使用 https 或自定义路径，可以手动覆盖
APP_URL=http://${APP_HOST}:${APP_PORT}

# GitHub 用户名（用于拉取 GHCR 镜像，源作者已预置）
# ⚠️ GHCR 镜像路径要求全小写，所以 RealKiro → realkiro
# 如果你 Fork 了仓库自行构建，改为你的 GitHub 用户名（小写）
GITHUB_USERNAME=realkiro


# ============================================================
# ===== 数据库配置 =====
# ============================================================
#
# 重要概念（阅读后可删除）：
#
#   DB_PASSWORD — Laravel 应用连接数据库时使用的密码
#     config/database.php 通过 Env::get('DB_PASSWORD') 读取
#     不管是 MySQL/MariaDB/PostgreSQL，Laravel 都用这一个
#
#   MYSQL_ROOT_PASSWORD — 仅用于内置 MySQL Docker 容器（mysql:8.8.0 镜像）首次初始化
#     设置 MySQL 服务器的 root 超管密码，用于数据库维护、备份、恢复
#     ⚠️ Laravel 从不读取此变量！
#     ⚠️ 使用外部数据库、SQLite 或 PostgreSQL 时，无需设置此变量
#     ⚠️ 建议与 DB_PASSWORD 不同，不要把 root 密码给业务应用
#
#   MYSQL_PORT — 宿主机上暴露的端口，供 Navicat/DBeaver 等工具连接
#     容器内部仍用 3306，DB_PORT 保持 3306 不动
#     示例：宿主机端口改成 3307 后，Navicat 连 yourIP:3307，但 DB_PORT 仍为 3306
#

# 数据库类型：mysql | pgsql | sqlite
# mysql 适用于 MySQL 8.0+ 和 MariaDB 10.3+（完全兼容）
DB_CONNECTION=mysql

# --- 默认值对应场景一（内置 MySQL 容器）---
# 切换到场景二/三/四时，取消下方对应注释块并注释掉此区域
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=learnstar
DB_USERNAME=learnstar
DB_PASSWORD=learnstar_password

# --- 内置 MySQL 容器专用（场景二/三/四忽略）---
MYSQL_ROOT_PASSWORD=root_strong_password
MYSQL_PORT=3306

# --------------------------------------------------------
# 以下为各场景完整示例，取消注释即可切换（同时注释掉上方默认值）
# --------------------------------------------------------

# === 场景二：外部 MySQL / MariaDB ===
# 已有外部 MariaDB/MySQL（如 NAS 自带数据库、云数据库 RDS）
# 步骤：1. 在外部数据库中手动创建 learnstar 库（如用 Adminer）
#       2. 取消以下注释并填写你的实际地址、账号、密码
#       3. MYSQL_ROOT_PASSWORD 和 MYSQL_PORT 无需设置（可删除或保留，不影响）
#       4. 启动命令：docker-compose up -d app --no-deps
#
# DB_CONNECTION=mysql
# DB_HOST=192.168.1.50           # ← 外部数据库 IP 或域名
# DB_PORT=3306                   # ← 外部数据库端口（MariaDB 默认 3306）
# DB_DATABASE=learnstar          # ← 外部数据库中已创建的库名
# DB_USERNAME=root               # ← 外部数据库用户名（如 root）
# DB_PASSWORD=your_mariadb_pass  # ← 外部数据库密码

# === 场景三：PostgreSQL ===
# 使用外部 PostgreSQL（需在外部 PG 中手动创建 learnstar 库和用户）
# 步骤：1. 在 PostgreSQL 中创建数据库和用户
#       2. 取消以下注释并填写实际配置
#       3. MYSQL_ROOT_PASSWORD 和 MYSQL_PORT 无需设置
#       4. 启动命令：docker-compose up -d app --no-deps
#
# DB_CONNECTION=pgsql
# DB_HOST=192.168.1.50           # ← PostgreSQL 地址
# DB_PORT=5432                   # ← PostgreSQL 默认端口
# DB_DATABASE=learnstar          # ← PG 中已创建的库名
# DB_USERNAME=learnstar_user     # ← PG 用户名
# DB_PASSWORD=your_pg_password   # ← PG 密码

# === 场景四：SQLite ===
# 最简单部署，无需任何数据库服务，适合小型部署（< 500 学生）
# 步骤：1. 取消以下注释
#       2. 缓存驱动建议改为 file（见下方 Redis/缓存配置区）
#       3. MYSQL_ROOT_PASSWORD 和 MYSQL_PORT 无需设置
#       4. 启动命令：docker-compose up -d app --no-deps
#       5. 数据库文件自动创建于 storage/database.sqlite
#
# DB_CONNECTION=sqlite
# DB_HOST=                       # SQLite 忽略
# DB_PORT=                       # SQLite 忽略
# DB_DATABASE=                   # SQLite 忽略
# DB_USERNAME=                   # SQLite 忽略
# DB_PASSWORD=                   # SQLite 忽略
# ⚠️ 使用 SQLite 时，建议同步修改下方缓存配置：
# CACHE_DRIVER=file
# SESSION_DRIVER=file
# QUEUE_CONNECTION=database


# ===== 超级管理员配置（首次部署时自动创建）=====
# 启动时会自动创建一个默认学校和一个 school_admin 账号
# 如果该用户名已存在，则不会重复创建，也不会修改密码
# ⚠️ 生产环境请务必修改默认密码！
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_NAME=系统管理员
ADMIN_SCHOOL_NAME=学趣星球默认学校
ADMIN_SCHOOL_CODE=learnstar-default


# ===== Redis 配置 =====
# 内置 Redis 容器：保持默认（REDIS_HOST=redis 是 Docker 内部网络名）
# 外部 Redis：改为外部地址
# ⚠️ 使用 SQLite 且无 Redis 时，需同步修改下方缓存配置（改为 file/database）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== 缓存配置 =====
# 使用内置/外部 Redis 时保持默认
# ⚠️ 使用 SQLite 且无 Redis 时，改为：
#   CACHE_DRIVER=file
#   SESSION_DRIVER=file
#   QUEUE_CONNECTION=database
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis


# ===== AI 功能配置（可选）=====
# 支持：qwen / openai / deepseek / moonshot
# 没有 API Key？没关系！所有核心功能都可正常使用，AI 在配置后自动启用
AI_PROVIDER=
AI_API_KEY=
AI_API_BASE=
AI_MODEL=qwen-turbo
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7


# ===== 第三方登录配置（可选）=====
# 微信公众号
WECHAT_OFFICIAL_APPID=
WECHAT_OFFICIAL_SECRET=

# 企业微信
WECHAT_WORK_CORPID=
WECHAT_WORK_AGENTID=
WECHAT_WORK_SECRET=

# QQ 登录
QQ_APPID=
QQ_APPSECRET=

# 人人通空间
RENREN_CLIENT_ID=
RENREN_CLIENT_SECRET=


# ===== 文件上传配置 =====
FILESYSTEM_DISK=local
UPLOAD_MAX_SIZE=10


# ===== 邮件配置（可选）=====
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=学趣星球
