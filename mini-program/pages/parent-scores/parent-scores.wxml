<view class="page">
  <view class="card"><text style="font-size:32rpx;font-weight:700;">📊 积分明细</text></view>
  <view wx:for="{{scores}}" wx:key="id" class="card score-item">
    <view style="display:flex;justify-content:space-between;align-items:center;">
      <view><text style="font-weight:500;font-size:28rpx;">{{item.reason}}</text><text style="font-size:22rpx;color:#94A3B8;display:block;">{{item.created_at}}</text></view>
      <text style="font-size:36rpx;font-weight:700;{{item.amount > 0 ? 'color:#10B981' : 'color:#EF4444'}};">{{item.amount > 0 ? '+' : ''}}{{item.amount}}</text>
    </view>
  </view>
  <view wx:if="{{loading}}" style="text-align:center;padding:48rpx;color:#64748B;">加载中...</view>
</view>
