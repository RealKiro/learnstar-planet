<view class="page">
  <view class="card"><text style="font-size:32rpx;font-weight:700;">🏆 班级排行</text></view>
  <view wx:if="{{myRank}}" class="card" style="background:linear-gradient(135deg,#4F46E5,#818CF8);margin:8rpx 16rpx;">
    <text style="color:white;font-size:28rpx;font-weight:600;">我的孩子: {{myRank.student_name}} · 第{{myRank.rank}}名</text>
    <text style="color:rgba(255,255,255,0.8);font-size:24rpx;display:block;">{{myRank.score}} 分</text>
  </view>
  <view wx:for="{{rankings}}" wx:key="*this" class="card" style="margin:6rpx 16rpx;{{item.is_mine ? 'border:2rpx solid #4F46E5;' : ''}}">
    <view style="display:flex;align-items:center;gap:12rpx;">
      <text style="font-size:32rpx;font-weight:700;min-width:50rpx;">{{item.rank <= 3 ? ['🥇','🥈','🥉'][item.rank-1] : item.rank}}</text>
      <view style="flex:1;"><text style="font-weight:600;font-size:28rpx;">{{item.student_name}}</text></view>
      <text style="font-size:28rpx;color:#4F46E5;font-weight:600;">{{item.score}}分</text>
    </view>
  </view>
  <view wx:if="{{loading}}" style="text-align:center;padding:48rpx;color:#64748B;">加载中...</view>
</view>
