<view class="page">
  <view style="display:flex;gap:12rpx;padding:16rpx;">
    <view class="stat-item"><text class="stat-value">{{stats.total}}</text><text class="stat-label">总宠物</text></view>
    <view class="stat-item"><text class="stat-value">{{stats.avg_level}}</text><text class="stat-label">平均等级</text></view>
    <view class="stat-item"><text class="stat-value">{{stats.max_level}}</text><text class="stat-label">最高等级</text></view>
  </view>
  <view wx:for="{{pets}}" wx:key="student_name" class="card" style="margin:12rpx 16rpx;">
    <view style="display:flex;align-items:center;gap:16rpx;">
      <text style="font-size:48rpx;">{{item.emoji}}</text>
      <view style="flex:1;">
        <text style="font-weight:600;font-size:28rpx;">{{item.student_name}} · {{item.pet_name}}</text>
        <view style="display:flex;gap:8rpx;margin-top:4rpx;">
          <text style="font-size:22rpx;color:#4F46E5;background:rgba(79,70,229,0.08);padding:4rpx 12rpx;border-radius:8rpx;">Lv.{{item.level}}</text>
          <text style="font-size:22rpx;color:#64748B;">{{item.stage}}</text>
        </view>
      </view>
    </view>
  </view>
  <view wx:if="{{loading}}" style="text-align:center;padding:48rpx;color:#64748B;">加载中...</view>
  <view wx:if="{{!loading && pets.length === 0}}" style="text-align:center;padding:48rpx;color:#64748B;">暂无宠物数据</view>
</view>
