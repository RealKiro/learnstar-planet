.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0F172A 0%, #1E293B 50%, #4F46E5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.brand-area {
  text-align: center;
  margin-bottom: 40rpx;
}
.brand-emoji { font-size: 100rpx; display: block; }
.brand-name { font-size: 48rpx; font-weight: 700; color: #F1F5F9; display: block; margin-top: 16rpx; }
.brand-sub { font-size: 26rpx; color: #94A3B8; display: block; margin-top: 8rpx; margin-bottom: 32rpx; }

/* 登录类型Tab */
.login-tabs {
  display: flex;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  border: 1px solid rgba(255,255,255,0.12);
  padding: 6rpx;
  margin-bottom: 32rpx;
  width: 100%;
}
.login-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #94A3B8;
  border-radius: 18rpx;
  transition: all 0.2s;
}
.tab-teacher-active {
  background: linear-gradient(135deg, #4F46E5, #818CF8);
  color: #F1F5F9;
  box-shadow: 0 4rpx 16rpx rgba(79,70,229,0.3);
}
.tab-admin-active {
  background: linear-gradient(135deg, #F59E0B, #D97706);
  color: #F1F5F9;
  box-shadow: 0 4rpx 16rpx rgba(245,158,11,0.3);
}

/* 表单区 */
.form-area {
  width: 100%;
  background: rgba(255,255,255,0.06);
  backdrop-filter: blur(40px);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 32rpx;
  padding: 48rpx;
}

.input-group { margin-bottom: 32rpx; }
.input-label { font-size: 26rpx; color: #CBD5E1; margin-bottom: 8rpx; display: block; }
.input-field {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  color: #F1F5F9;
  font-size: 30rpx;
  width: 100%;
}

/* 教师登录按钮 */
.teacher-btn {
  background: linear-gradient(135deg, #4F46E5, #818CF8);
  color: white;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 16rpx;
  border: none;
}

/* 管理员登录按钮 */
.admin-btn {
  background: linear-gradient(135deg, #F59E0B, #D97706);
  color: white;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 16rpx;
  border: none;
}

/* 管理员提示 */
.admin-notice {
  background: rgba(245,158,11,0.08);
  border: 1px solid rgba(245,158,11,0.15);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
  color: #FCD34D;
  font-size: 26rpx;
  line-height: 1.6;
}

.divider {
  color: #64748B;
  text-align: center;
  margin: 40rpx 0 24rpx;
  font-size: 24rpx;
}

.wx-login-btn {
  background: rgba(7,193,96,0.1);
  border: 1px solid rgba(7,193,96,0.3);
  color: #07C160;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.bind-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #F1F5F9;
  margin-bottom: 16rpx;
}
.bind-tip {
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 32rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #64748B;
  text-align: center;
  margin-top: 24rpx;
  display: block;
}
.back-link {
  color: #818CF8;
  cursor: pointer;
}
