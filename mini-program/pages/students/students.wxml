<view class="page">
  <view class="card" style="margin-bottom:16rpx;">
    <input placeholder="搜索学生姓名或学号" bindinput="onSearch" style="padding:16rpx;background:#F1F5F9;border-radius:12rpx;font-size:28rpx;" />
  </view>
  <view wx:for="{{students}}" wx:key="id" class="card student-item" data-id="{{item.id}}" bindtap="viewDetail">
    <view style="display:flex;align-items:center;gap:16rpx;">
      <text style="font-size:40rpx;">{{item.pet_emoji || '👤'}}</text>
      <view style="flex:1;">
        <text style="font-weight:600;font-size:28rpx;">{{item.name}}</text>
        <text style="font-size:24rpx;color:#64748B;display:block;" wx:if="{{item.student_no}}">学号: {{item.student_no}}</text>
      </view>
      <text style="font-size:28rpx;color:#4F46E5;font-weight:600;">{{item.total_score || 0}}分</text>
    </view>
  </view>
  <view wx:if="{{loading}}" style="text-align:center;padding:48rpx;color:#64748B;">加载中...</view>
  <view wx:if="{{!loading && students.length === 0}}" style="text-align:center;padding:48rpx;color:#64748B;">暂无学生数据</view>
</view>
