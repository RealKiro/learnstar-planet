# ========== IDE ==========
.idea/
.vscode/
*.swp
*.swo
*.bak
*~
.DS_Store
Thumbs.db
desktop.ini

# ========== OS ==========
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ========== Docker ==========
docker/data/
docker/volumes/

